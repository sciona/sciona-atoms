      ],
      "depth": 1,
      "type_signature": "(temper_val: float, target_log_kernel: callable, rng_key_in: RNG state / PRNGKey) -> tuple[object, RNG state / PRNGKey]",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "Temperature-Scaled Stochastic Accept-Reject State Transition. Performs one Markovian update on a current state by generating a candidate state, evaluating log-compatibility scores for current and candidate configurations, and computing an acceptance ratio under a temperature-scaled criterion. The output state is either the candidate or the original state based on a stochastic accept/reject draw, while preserving the information needed for downstream diagnostics and chaining.. Applications: Sampling feasible high-dimensional conformations in computational structural biology, Exploring posterior parameter fields in geophysical or medical inverse imaging, State-space exploration for uncertainty-aware trajectory generation in robotics, Equilibrium configuration sampling in statistical physics lattice/particle systems",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
