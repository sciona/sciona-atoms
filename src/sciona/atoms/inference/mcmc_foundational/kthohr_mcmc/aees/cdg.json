          "type_desc": "np.ndarray",
          "constraints": "Thread explicitly for purity when stochastic proposal/acceptance draws are used."
        }
      ],
      "outputs": [
        {
          "name": "mh_step_state_out",
          "type_desc": "object",
          "constraints": "Immutable result containing next sample and acceptance-related values."
        },
        {
          "name": "rng_key_out",
          "type_desc": "np.ndarray",
          "constraints": "New key/state after any random draws."
        }
      ],
      "status": "decomposed",
