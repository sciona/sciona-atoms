    {
      "node_id": "targetlogkerneloracle",
      "parent_id": "single_step_mh_root",
      "name": "TargetLogKernelOracle",
      "description": "Stateless oracle that evaluates target log-kernel values for candidate/current states used by MH acceptance logic.",
      "concept_type": "probabilistic_oracle",
      "inputs": [
        {
          "name": "state_candidate",
