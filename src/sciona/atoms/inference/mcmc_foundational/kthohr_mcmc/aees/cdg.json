        {
          "name": "temper_val",
          "type_desc": "float",
          "constraints": "Must be > 0 for sqrt and division."
        },
        {
          "name": "prop_scaling_mat",
          "type_desc": "Mat_t",
          "constraints": "Compatible with X_prev and rand_vec dimensions."
