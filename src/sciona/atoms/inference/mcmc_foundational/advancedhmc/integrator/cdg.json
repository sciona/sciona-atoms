      "node_id": "proposenextphasepointwithtemperedleapfrog",
      "parent_id": "hamiltonianphasepointtransition",
      "name": "ProposeNextPhasepointWithTemperedLeapfrog",
      "description": "Execute one leapfrog proposal: pre-temper momentum, half momentum update, full position update via dH/dr, second half momentum update via dH/dtheta, post-temper, then build a cached phase-point candidate.",
      "concept_type": "sampler",
      "inputs": [
        {
          "name": "lf",
          "type_desc": "object",
          "constraints": "must support temper"
        },
        {
          "name": "h",
          "type_desc": "Hamiltonian",
          "constraints": "must support dH/dr, dH/dtheta, and phasepoint construction"
        },
        {
          "name": "loop_state",
          "type_desc": "object",
          "constraints": "contains current iteration index and state"
        },
        {
          "name": "step_count",
          "type_desc": "Int",
          "constraints": "used by temper schedule"
        },
        {
          "name": "epsilon",
          "type_desc": "float",
          "constraints": "broadcast-compatible with theta, r, gradient"
        }
      ],
      "outputs": [
        {
          "name": "candidate_state",
          "type_desc": "object",
          "constraints": "z_candidate = phasepoint(h, theta_next, r_next; lpi=DualValue(value_next, gradient_next))"
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
