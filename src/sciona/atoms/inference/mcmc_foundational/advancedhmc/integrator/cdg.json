    {
      "node_id": "temperingfactorcomputation",
      "parent_id": "step_root",
      "name": "TemperingFactorComputation",
      "description": "Computes a deterministic tempering multiplier across sub-steps (with bounds checking) to scale the transition strength.",
      "concept_type": "mcmc_proposal",
      "inputs": [
        {
          "name": "lf",
          "type_desc": "object",
          "constraints": "Read-only; no persistent mutation"
        },
        {
          "name": "r",
          "type_desc": "float",
          "constraints": "Finite"
        },
        {
          "name": "step",
          "type_desc": "Integer",
          "constraints": "0 <= step <= n_steps"
        },
        {
          "name": "n_steps",
          "type_desc": "Integer",
          "constraints": "Positive"
        }
      ],
      "outputs": [
        {
          "name": "tempering_scale",
          "type_desc": "float",
          "constraints": "Deterministic function of inputs"
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 1,
      "type_signature": "(lf: Leapfrog/state-transition context, r: Real scalar, step: Integer, n_steps: Integer) -> Real scalar",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "IndexedTransitionGainSchedule. Maps a global intensity parameter and a discrete sub-step index to a deterministic scalar gain used to modulate update magnitude within a multi-step process. The computation enforces index validity against the total step count, yielding a well-defined scaling factor for every admissible sub-step. This is a pure schedule evaluation: no persistent state is mutated, and output is fully determined by the provided inputs.. Applications: Adaptive learning-rate scaling across inner iterations of numerical optimization in scientific computing, Stepwise trust-region or damping control in nonlinear equation solvers for computational physics, Scheduled actuation gain modulation across micro-steps in robotic trajectory execution, Progressive regularization-strength scheduling over sub-epochs in neural network training",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
    {
      "node_id": "hamiltonianphasepointtransition",
      "parent_id": "step_root",
      "name": "HamiltonianPhasepointTransition",
      "description": "Executes one pure Hamiltonian transition kernel step by computing derivatives, applying step-size/tempering, and returning a new phase-point state.",
      "concept_type": "mcmc_kernel",
      "inputs": [
        {
          "name": "lf",
          "type_desc": "object",
          "constraints": "Read-only; no persistent mutation"
        },
        {
          "name": "h",
          "type_desc": "object",
          "constraints": "Immutable input state"
        },
        {
          "name": "z",
          "type_desc": "object",
          "constraints": "Finite where required"
        },
        {
          "name": "tempering_scale",
          "type_desc": "float",
          "constraints": "Provided by tempering computation"
        }
      ],
      "outputs": [
        {
          "name": "h_next",
          "type_desc": "object",
          "constraints": "New immutable state object (state_out)"
        },
        {
          "name": "is_valid",
          "type_desc": "Boolean",
          "constraints": "True iff finite/valid transition"
        }
      ],
      "status": "decomposed",
      "children": [
        "normalizeintegrationcontrols",
        "initializeloopstatefromphasepoint",
        "proposenextphasepointwithtemperedleapfrog",
        "commitcandidateanddecidecontinuation",
        "assembletransitionresult"
      ],
      "depth": 1,
      "type_signature": "(lf: Leapfrog/state-transition context, h: Phase-point or Hamiltonian state, z: Auxiliary state/value, tempering_scale: Real scalar) -> tuple[Phase-point or Hamiltonian state, Boolean]",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "Tempered Symplectic State Transition Step. Takes an immutable composite state and a read-only transition context, evaluates derivative fields of an underlying scalar potential, and applies one discretized symplectic update scaled by a real tempering factor. The operation produces a new immutable state instance representing a single Markov transition. A numerical validity check flags whether the resulting state remains finite and admissible.. Applications: Bayesian parameter posterior exploration in nonlinear robotics system identification, Latent-field sampling for geophysical inverse modeling from sparse sensor measurements, Posterior sampling of high-dimensional neural-network parameters in Bayesian deep learning, Microstate exploration in computational materials or molecular simulation under energy constraints",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
    {
      "node_id": "normalizeintegrationcontrols",
      "parent_id": "hamiltonianphasepointtransition",
      "name": "NormalizeIntegrationControls",
      "description": "Convert integration controls into canonical form: absolute step count, signed step size based on direction, and trajectory collection mode.",
      "concept_type": "arithmetic",
      "inputs": [
        {
          "name": "lf",
          "type_desc": "object",
          "constraints": "must provide step_size(lf)"
        },
        {
          "name": "n_steps",
          "type_desc": "Int",
          "constraints": "can be negative; magnitude determines number of iterations"
        },
        {
          "name": "fwd",
          "type_desc": "Bool",
          "constraints": "true for forward integration, false for backward"
        },
        {
          "name": "full_trajectory",
          "type_desc": "bool",
          "constraints": "compile-time flag"
        }
      ],
      "outputs": [
        {
          "name": "step_count",
          "type_desc": "Int",
          "constraints": "step_count = abs(n_steps), step_count >= 0"
        },
        {
          "name": "epsilon",
          "type_desc": "float",
          "constraints": "epsilon = (fwd ? step_size(lf) : -step_size(lf))'"
        },
        {
          "name": "collect_full_trajectory",
          "type_desc": "Bool",
          "constraints": "true iff full_trajectory is Val(true)"
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
      "type_signature": "(lf: DefaultLeapfrog context, n_steps: Int, fwd: Bool, full_trajectory: Val{Bool}) -> tuple[Int, Step-size scalar/vector compatible with theta and r, Bool]",
